ALLOWED_ORIGINS='http://localhost:5173,http://localhost:3000'
APP_TIMEZONE=America/Recife
JWT_SECRET=replace_with_a_secure_secret
JWT_EXPIRATION=3600000

# ===========================================
# KEYCLOAK CONFIGURATION
# ===========================================
# URL base do servidor Keycloak (sem /realms)
KEYCLOAK_AUTH_SERVER_URL=https://keycloak.seudominio.com.br
# Nome do realm no Keycloak
KEYCLOAK_REALM=seu-realm
# Client ID da aplicação registrada no Keycloak
KEYCLOAK_CLIENT_ID=seu-client-id
KEYCLOAK_CLIENT_SECRET=seu-client-secret
# Token URL - IMPORTANT: Modern Keycloak (v20+) uses /realms path (NOT /auth/realms)
# Example: https://keycloak.seudominio.com.br/realms/seu-realm/protocol/openid-connect/token
KEYCLOAK_TOKEN_URL=https://keycloak.seudominio.com.br/realms/seu-realm/protocol/openid-connect/token
KEYCLOAK_REDIRECT_URI=http://localhost:5173
KEYCLOAK_PROVIDER_ISSUER=https://keycloak.seudominio.com.br/realms/seu-realm

ROLE_ADMIN=NETNOTIFY_ADMIN
ROLE_USER=NETNOTIFY_USER

PORT=8080

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=netnotify

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=netnotify_topic
RABBITMQ_EXCHANGE_DURABLE=true
RABBITMQ_QUEUE=notification_queue
RABBITMQ_ROUTING_KEY=notification_key

# ============================================================================
# RabbitMQ - Credenciais Segregadas
# ============================================================================
# Produtor (Servidor NetNotify): permissões write + configure
RABBITMQ_ADMIN_PRODUCER_USER=admin-producer
RABBITMQ_ADMIN_PRODUCER_PASS=adminproducer123

# Consumidor (Agentes): permissões read-only
RABBITMQ_AGENT_CONSUMER_USER=agent-consumer
RABBITMQ_AGENT_CONSUMER_PASS=agentconsumer123

# Token de autenticação para agentes (deve ser um valor seguro e único)
AGENT_API_TOKEN=replace_with_secure_token_for_agents

# ===========================================
# REACT APP CONFIGURATION
# ===========================================
# URL base do aplicativo React que receberá as informações de autenticação
REACT_APP_URL=http://localhost:5173/auth/login

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=








